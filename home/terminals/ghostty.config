# Ghostty — Doom Vibrant theme + Doom-Emacs-style C-Space leader scheme.
# Mirrors home/kitty-thinkpad.nix, home/wezterm/wezterm.lua and
# home/shell/tmux.conf: leader = Ctrl+Space, key-tables w/b/p/t/o, vim hjkl
# navigation, HJKL resize. Ghostty has native splits + tabs, so unlike
# Alacritty it can reproduce the full muxing scheme without tmux.

# ── Font ────────────────────────────────────────────────────────────────────
font-family = Maple Mono NF
font-size = 12
# Ligatures — Maple Mono ships programming ligatures via calt/liga/dlig.
font-feature = calt
font-feature = liga
font-feature = dlig

# ── Doom Vibrant palette (Henrik Lissner) ───────────────────────────────────
background = 242730
foreground = bbc2cf
cursor-color = bbc2cf
cursor-text = 242730
cursor-style = bar
selection-background = 3d4451
selection-foreground = bbc2cf

# palette index = colourN from the kitty config
palette = 0=#2a2e38
palette = 8=#484854
palette = 1=#ff665c
palette = 9=#ff665c
palette = 2=#7bc275
palette = 10=#99bb66
palette = 3=#fcce7b
palette = 11=#ecbe7b
palette = 4=#51afef
palette = 12=#51afef
palette = 5=#c57bdb
palette = 13=#c678dd
palette = 6=#5cefff
palette = 14=#46d9ff
palette = 7=#dfdfdf
palette = 15=#bbc2cf

# ── Appearance ──────────────────────────────────────────────────────────────
window-padding-x = 6
window-padding-y = 6
background-opacity = 1.0
# Tab bar. Ghostty 1.3.1 has NO vertical/side tabs — gtk-tabs-location only
# accepts top | bottom | hidden. Tabs are at the bottom (content above them).
# No per-tab colour from config, but the whole AdwTabBar is themed via
# gtk-custom-css below (see ghostty-tabs.css). gtk-titlebar-style `tabs` would
# instead merge pill-tabs into the header bar.
window-theme        = ghostty
gtk-tabs-location   = bottom
gtk-titlebar-style  = native
gtk-wide-tabs       = true
# Doom Vibrant / wezterm-inspired tab styling (close-on-hover, active accent).
gtk-custom-css      = /home/wap/.config/ghostty/ghostty-tabs.css

# ── Behaviour / productivity ─────────────────────────────────────────────────
# Nix owns the binary — never self-check for updates.
auto-update = off
# Restore splits + tabs across restarts.
window-save-state = always
# Bell/notify when a long command finishes in an *unfocused* split or tab.
notify-on-command-finish = unfocused
# QoL.
mouse-hide-while-typing = true
window-padding-balance  = true
# Tiling WM: drop the GTK client-side titlebar — Hyprland draws the border and
# the tab bar lives at the bottom, so the header bar is wasted vertical space.
gtk-titlebar = false
# Padding fills with the background colour (seamless edges, no theme band).
window-padding-color = background
# Never let fg collapse into bg (guards unreadable same-colour text).
minimum-contrast = 1.05
# Hover a link to preview its target before clicking.
link-previews = true

# ── Quick terminal (Variant B — Ghostty-native drop-down) ────────────────────
# NOTE: on Linux/Wayland Ghostty has NO global hotkey, so this can only be
# summoned WHILE a Ghostty is focused (keybind: ctrl+space>t>q). For a truly
# global drop-down use the Hyprland special:scratch scratchpad (SUPER+minus).
# Both are wired so you can A/B them; delete the loser later.
quick-terminal-position           = top
quick-terminal-animation-duration = 0.15
quick-terminal-autohide           = true
gtk-quick-terminal-layer          = overlay

# ── Leader scheme ───────────────────────────────────────────────────────────
# Ghostty expresses Doom-style prefixes as literal key *sequences* with `>`.
# ctrl+space is the leader, matching kitty / wezterm / tmux.

# Reload + send-leader passthrough
keybind = ctrl+space>r=reload_config
keybind = ctrl+space>ctrl+space=text:\x00

# Command palette — fuzzy every action (direct, non-leader).
keybind = ctrl+shift+p=toggle_command_palette

# Split navigation (vim hjkl). Ghostty 1.3.1 goto_split takes
# up|down|left|right|next|previous — NOT top/bottom (silently dropped).
keybind = ctrl+space>h=goto_split:left
keybind = ctrl+space>j=goto_split:down
keybind = ctrl+space>k=goto_split:up
keybind = ctrl+space>l=goto_split:right

# Split resize (Shift+HJKL)
keybind = ctrl+space>shift+h=resize_split:left,10
keybind = ctrl+space>shift+j=resize_split:down,10
keybind = ctrl+space>shift+k=resize_split:up,10
keybind = ctrl+space>shift+l=resize_split:right,10

# w — window/pane key-table (v = side-by-side, s = stacked; matches tmux)
keybind = ctrl+space>w>v=new_split:right
keybind = ctrl+space>w>s=new_split:down
keybind = ctrl+space>w>c=close_surface
keybind = ctrl+space>w>z=toggle_split_zoom
keybind = ctrl+space>w>equal=equalize_splits

# s — scroll / search key-table (letter keys — DE layout has brackets on AltGr).
# jump_to_prompt needs shell-integration marks (enabled by default).
keybind = ctrl+space>s>s=start_search
keybind = ctrl+space>s>k=jump_to_prompt:-1
keybind = ctrl+space>s>j=jump_to_prompt:1
keybind = ctrl+space>s>t=scroll_to_top
keybind = ctrl+space>s>b=scroll_to_bottom
keybind = ctrl+space>s>e=write_scrollback_file:open

# b — buffer/tab key-table
keybind = ctrl+space>b>o=toggle_tab_overview
keybind = ctrl+space>b>n=next_tab
keybind = ctrl+space>b>p=previous_tab
keybind = ctrl+space>b>c=new_tab
keybind = ctrl+space>b>k=close_surface
keybind = ctrl+space>b>1=goto_tab:1
keybind = ctrl+space>b>2=goto_tab:2
keybind = ctrl+space>b>3=goto_tab:3
keybind = ctrl+space>b>4=goto_tab:4
keybind = ctrl+space>b>5=goto_tab:5
keybind = ctrl+space>b>6=goto_tab:6
keybind = ctrl+space>b>7=goto_tab:7
keybind = ctrl+space>b>8=goto_tab:8
keybind = ctrl+space>b>9=goto_tab:9

# p — project/OS-window key-table
keybind = ctrl+space>p>n=new_window

# t — toggle key-table
keybind = ctrl+space>t>f=toggle_fullscreen
keybind = ctrl+space>t>z=toggle_split_zoom
keybind = ctrl+space>t>q=toggle_quick_terminal

# o — open key-table
keybind = ctrl+space>o>t=new_tab
keybind = ctrl+space>o>v=new_split:right
keybind = ctrl+space>o>s=new_split:down
