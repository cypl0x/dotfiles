# Ghostty — Doom Vibrant theme + Doom-Emacs-style C-Space leader scheme.
# Mirrors home/kitty-thinkpad.nix, home/wezterm/wezterm.lua and
# home/shell/tmux.conf: leader = Ctrl+Space, key-tables w/b/p/t/o, vim hjkl
# navigation, HJKL resize. Ghostty has native splits + tabs, so unlike
# Alacritty it can reproduce the full muxing scheme without tmux.

# ── Font ────────────────────────────────────────────────────────────────────
font-family = Maple Mono NF
font-size = 12

# ── Doom Vibrant palette (Henrik Lissner) ───────────────────────────────────
background = 242730
foreground = bbc2cf
cursor-color = bbc2cf
cursor-text = 242730
cursor-style = bar
selection-background = 3d4451
selection-foreground = bbc2cf

# palette index = colourN from the kitty config
palette = 0=#2a2e38
palette = 8=#484854
palette = 1=#ff665c
palette = 9=#ff665c
palette = 2=#7bc275
palette = 10=#99bb66
palette = 3=#fcce7b
palette = 11=#ecbe7b
palette = 4=#51afef
palette = 12=#51afef
palette = 5=#c57bdb
palette = 13=#c678dd
palette = 6=#5cefff
palette = 14=#46d9ff
palette = 7=#dfdfdf
palette = 15=#bbc2cf

# ── Appearance ──────────────────────────────────────────────────────────────
window-padding-x = 6
window-padding-y = 6
background-opacity = 1.0
# Tab bar. Ghostty 1.3.1 has NO vertical/side tabs — gtk-tabs-location only
# accepts top | bottom | hidden. No per-tab colour styling either (tabs follow
# the GTK/Adwaita theme, unlike wezterm's format-tab-title). For pill-style
# tabs merged into the header bar, switch gtk-titlebar-style to `tabs`.
window-theme        = ghostty
gtk-tabs-location   = top
gtk-titlebar-style  = native
gtk-wide-tabs       = true

# ── Leader scheme ───────────────────────────────────────────────────────────
# Ghostty expresses Doom-style prefixes as literal key *sequences* with `>`.
# ctrl+space is the leader, matching kitty / wezterm / tmux.

# Reload + send-leader passthrough
keybind = ctrl+space>r=reload_config
keybind = ctrl+space>ctrl+space=text:\x00

# Split navigation (vim hjkl)
keybind = ctrl+space>h=goto_split:left
keybind = ctrl+space>j=goto_split:bottom
keybind = ctrl+space>k=goto_split:top
keybind = ctrl+space>l=goto_split:right

# Split resize (Shift+HJKL)
keybind = ctrl+space>shift+h=resize_split:left,10
keybind = ctrl+space>shift+j=resize_split:down,10
keybind = ctrl+space>shift+k=resize_split:up,10
keybind = ctrl+space>shift+l=resize_split:right,10

# w — window/pane key-table (v = side-by-side, s = stacked; matches tmux)
keybind = ctrl+space>w>v=new_split:right
keybind = ctrl+space>w>s=new_split:down
keybind = ctrl+space>w>c=close_surface
keybind = ctrl+space>w>z=toggle_split_zoom
keybind = ctrl+space>w>equal=equalize_splits

# b — buffer/tab key-table
keybind = ctrl+space>b>n=next_tab
keybind = ctrl+space>b>p=previous_tab
keybind = ctrl+space>b>c=new_tab
keybind = ctrl+space>b>k=close_surface
keybind = ctrl+space>b>1=goto_tab:1
keybind = ctrl+space>b>2=goto_tab:2
keybind = ctrl+space>b>3=goto_tab:3
keybind = ctrl+space>b>4=goto_tab:4
keybind = ctrl+space>b>5=goto_tab:5
keybind = ctrl+space>b>6=goto_tab:6
keybind = ctrl+space>b>7=goto_tab:7
keybind = ctrl+space>b>8=goto_tab:8
keybind = ctrl+space>b>9=goto_tab:9

# p — project/OS-window key-table
keybind = ctrl+space>p>n=new_window

# t — toggle key-table
keybind = ctrl+space>t>f=toggle_fullscreen
keybind = ctrl+space>t>z=toggle_split_zoom

# o — open key-table
keybind = ctrl+space>o>t=new_tab
keybind = ctrl+space>o>v=new_split:right
keybind = ctrl+space>o>s=new_split:down
